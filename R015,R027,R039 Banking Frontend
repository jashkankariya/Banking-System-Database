  <!-- DB SCHEMA -->
  <div class="page" id="page-schema">
    <h2>Database Schema</h2>
    <div class="tabs">
      <div class="tab active" onclick="switchTab('er',this)">ER Diagram</div>
      <div class="tab" onclick="switchTab('rel',this)">Relational Model</div>
      <div class="tab" onclick="switchTab('norm',this)">Normalization</div>
      <div class="tab" onclick="switchTab('queries',this)">SQL Queries List</div>
    </div>

    <div class="tab-content active" id="tab-er">
      <div class="card">
        <h3>Entity-Relationship Diagram (Text Representation)</h3>
        <p style="font-size:13px;color:#555">The banking system has 9 entities connected by relationships as described below:</p>
        <table style="margin-top:10px">
          <thead><tr><th>Entity</th><th>Primary Key</th><th>Key Attributes</th><th>Relationships</th></tr></thead>
          <tbody>
            <tr><td><b>BANK</b></td><td>bank_id</td><td>bank_name, swift_code, headquarters</td><td>1 BANK has many BRANCHes</td></tr>
            <tr><td><b>BRANCH</b></td><td>branch_id</td><td>branch_name, city, ifsc_code</td><td>1 BRANCH has many EMPLOYEEs, ACCOUNTs, LOANs</td></tr>
            <tr><td><b>EMPLOYEE</b></td><td>emp_id</td><td>first_name, last_name, role, salary</td><td>Many EMPLOYEEs work in 1 BRANCH</td></tr>
            <tr><td><b>CUSTOMER</b></td><td>customer_id</td><td>name, pan_number, kyc_status, email</td><td>1 CUSTOMER has many ACCOUNTs and LOANs</td></tr>
            <tr><td><b>ACCOUNT</b></td><td>account_id</td><td>account_number, type, balance, status</td><td>1 ACCOUNT has many TRANSACTIONs and CARDs</td></tr>
            <tr><td><b>TRANSACTION</b></td><td>txn_id</td><td>txn_type, amount, txn_date, reference_no</td><td>Many TRANSACTIONs belong to 1 ACCOUNT</td></tr>
            <tr><td><b>CARD</b></td><td>card_id</td><td>card_number, card_type, expiry_date</td><td>Many CARDs linked to 1 ACCOUNT</td></tr>
            <tr><td><b>LOAN</b></td><td>loan_id</td><td>loan_type, principal, interest_rate, tenure</td><td>1 LOAN has many LOAN_PAYMENTs</td></tr>
            <tr><td><b>LOAN_PAYMENT</b></td><td>payment_id</td><td>emi_amount, principal_part, interest_part</td><td>Many PAYMENTs belong to 1 LOAN</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="tab-content" id="tab-rel">
      <div class="card">
        <h3>Relational Model</h3>
        <div class="schema-box">
          <div><span class="entity">BANK</span>(<span class="pk"><u>bank_id</u></span>, bank_name, headquarters, established, swift_code)</div>
          <div><span class="entity">BRANCH</span>(<span class="pk"><u>branch_id</u></span>, <span class="fk">bank_id*</span>, branch_name, city, state, ifsc_code)</div>
          <div><span class="entity">EMPLOYEE</span>(<span class="pk"><u>emp_id</u></span>, <span class="fk">branch_id*</span>, first_name, last_name, role, salary, hire_date)</div>
          <div><span class="entity">CUSTOMER</span>(<span class="pk"><u>customer_id</u></span>, first_name, last_name, dob, email, phone, address, pan_number, kyc_status)</div>
          <div><span class="entity">ACCOUNT</span>(<span class="pk"><u>account_id</u></span>, <span class="fk">customer_id*</span>, <span class="fk">branch_id*</span>, account_number, account_type, balance, open_date, status)</div>
          <div><span class="entity">TRANSACTION</span>(<span class="pk"><u>txn_id</u></span>, <span class="fk">account_id*</span>, txn_type, amount, txn_date, description, reference_no)</div>
          <div><span class="entity">CARD</span>(<span class="pk"><u>card_id</u></span>, <span class="fk">account_id*</span>, card_number, card_type, expiry_date, credit_limit, status)</div>
          <div><span class="entity">LOAN</span>(<span class="pk"><u>loan_id</u></span>, <span class="fk">customer_id*</span>, <span class="fk">branch_id*</span>, loan_type, principal, interest_rate, tenure_months, disburse_date, status)</div>
          <div><span class="entity">LOAN_PAYMENT</span>(<span class="pk"><u>payment_id</u></span>, <span class="fk">loan_id*</span>, payment_date, emi_amount, principal_part, interest_part)</div>
          <br>
          <div style="font-size:12px;color:#555"><span class="pk"><u>underline</u></span> = Primary Key &nbsp;|&nbsp; <span class="fk">blue *</span> = Foreign Key</div>
        </div>
      </div>
    </div>

    <div class="tab-content" id="tab-norm">
      <div class="card">
        <h3>Normalization</h3>
        <table>
          <thead><tr><th>Normal Form</th><th>Condition</th><th>Status</th><th>Explanation</th></tr></thead>
          <tbody>
            <tr><td><b>1NF</b></td><td>Atomic values, no repeating groups</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All columns hold single atomic values. Each row is unique via primary key.</td></tr>
            <tr><td><b>2NF</b></td><td>No partial dependency on composite key</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All PKs are single-column (surrogate keys), so partial dependency cannot exist.</td></tr>
            <tr><td><b>3NF</b></td><td>No transitive dependency</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>Branch details stored in BRANCH table, not in ACCOUNT. No non-key attribute depends on another non-key attribute.</td></tr>
            <tr><td><b>BCNF</b></td><td>Every determinant is a candidate key</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All functional dependencies have superkeys as determinants. Unique constraints (PAN, IFSC, account_number) are candidate keys.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="tab-content" id="tab-queries">
      <div class="card">
        <h3>SQL Queries</h3>
        <table>
          <thead><tr><th>#</th><th>Description</th><th>SQL Concept</th></tr></thead>
          <tbody>
            <tr><td>Q1</td><td>List all customers with KYC status</td><td>SELECT, ORDER BY</td></tr>
            <tr><td>Q2</td><td>Active accounts with balance &gt; 1 lakh</td><td>WHERE, JOIN, ORDER BY DESC</td></tr>
            <tr><td>Q3</td><td>Total balance by account type</td><td>GROUP BY, COUNT, SUM, AVG, MAX, MIN</td></tr>
            <tr><td>Q4</td><td>Branches with total loan &gt; 1 crore</td><td>JOIN, GROUP BY, HAVING</td></tr>
            <tr><td>Q5</td><td>Customer with account and branch details</td><td>INNER JOIN (3 tables)</td></tr>
            <tr><td>Q6</td><td>Customers with or without loans</td><td>LEFT JOIN</td></tr>
            <tr><td>Q7</td><td>Customers with above-average balance</td><td>Subquery in WHERE</td></tr>
            <tr><td>Q8</td><td>Employees earning above branch average</td><td>Correlated Subquery</td></tr>
            <tr><td>Q9</td><td>Transaction summary per account</td><td>GROUP BY with multiple JOINs</td></tr>
            <tr><td>Q10</td><td>Top 5 highest salary employees</td><td>ORDER BY DESC, LIMIT</td></tr>
            <tr><td>Q11</td><td>Accounts opened in last 3 years</td><td>DATE functions, TIMESTAMPDIFF</td></tr>
            <tr><td>Q12</td><td>Customer category by balance</td><td>CASE statement</td></tr>
            <tr><td>Q13</td><td>Masked card number display</td><td>String functions: CONCAT, RIGHT</td></tr>
            <tr><td>Q14</td><td>Mark dormant accounts</td><td>UPDATE with subquery</td></tr>
            <tr><td>Q15</td><td>Show closed loans</td><td>SELECT with filter</td></tr>
            <tr><td>Q16</td><td>Customer loan summary view</td><td>CREATE VIEW</td></tr>
            <tr><td>Q17</td><td>Create indexes for performance</td><td>CREATE INDEX</td></tr>
            <tr><td>Q18</td><td>Fund transfer between accounts</td><td>START TRANSACTION, COMMIT</td></tr>
            <tr><td>Q19</td><td>Customers with account and loan both</td><td>EXISTS subquery</td></tr>
            <tr><td>Q20</td><td>Loans and FD accounts combined</td><td>UNION ALL</td></tr>
            <tr><td>Q21</td><td>EMI calculation for each loan</td><td>Mathematical functions, POW</td></tr>
            <tr><td>Q22</td><td>Full profile view for a customer</td><td>Multi-table LEFT JOIN</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div><!-- end container -->

