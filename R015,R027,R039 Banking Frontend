<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Banking System Database</title>
<style>
  body { font-family: Arial, sans-serif; margin: 0; background: #f0f0f0; }
  h1 { background: #003366; color: white; padding: 15px 20px; margin: 0; font-size: 22px; }
  h1 span { font-size: 13px; font-weight: normal; display: block; margin-top: 3px; }

  .navbar { background: #004080; display: flex; flex-wrap: wrap; }
  .navbar a { color: white; padding: 10px 16px; text-decoration: none; font-size: 14px; cursor: pointer; display: block; }
  .navbar a:hover, .navbar a.active { background: #0066cc; }

  .container { padding: 20px; max-width: 1100px; margin: auto; }
  .page { display: none; }
  .page.active { display: block; }

  h2 { color: #003366; border-bottom: 2px solid #003366; padding-bottom: 5px; font-size: 18px; }
  h3 { color: #004080; font-size: 15px; margin-top: 20px; }

  table { width: 100%; border-collapse: collapse; background: white; margin-top: 10px; font-size: 13px; }
  th { background: #003366; color: white; padding: 8px 10px; text-align: left; }
  td { padding: 7px 10px; border-bottom: 1px solid #ddd; }
  tr:nth-child(even) { background: #f9f9f9; }
  tr:hover { background: #e8f0fe; }

  .card { background: white; border: 1px solid #ccc; padding: 15px; margin-bottom: 15px; border-radius: 4px; }
  .kpi-row { display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 20px; }
  .kpi { background: white; border: 1px solid #ccc; border-left: 4px solid #003366; padding: 12px 16px; min-width: 150px; border-radius: 3px; }
  .kpi .num { font-size: 24px; font-weight: bold; color: #003366; }
  .kpi .lbl { font-size: 12px; color: #666; margin-top: 3px; }

  input[type=text], input[type=number], input[type=email], input[type=date], select {
    padding: 6px 8px; border: 1px solid #aaa; border-radius: 3px; font-size: 13px; width: 100%;
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .form-group { display: flex; flex-direction: column; gap: 4px; }
  .form-group label { font-size: 12px; font-weight: bold; color: #333; }
  button { padding: 7px 16px; background: #003366; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 13px; margin-right: 5px; }
  button:hover { background: #0055aa; }
  button.cancel { background: #888; }
  button.cancel:hover { background: #666; }

  .badge { padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
  .badge-green { background: #d4edda; color: #155724; }
  .badge-yellow { background: #fff3cd; color: #856404; }
  .badge-red { background: #f8d7da; color: #721c24; }
  .badge-blue { background: #cce5ff; color: #004085; }
  .badge-grey { background: #e2e3e5; color: #383d41; }

  .modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 100; }
  .modal-bg.open { display: flex; align-items: center; justify-content: center; }
  .modal { background: white; padding: 20px; width: 480px; border-radius: 4px; border-top: 4px solid #003366; }
  .modal h3 { margin-top: 0; color: #003366; }
  .modal-footer { margin-top: 15px; }

  .toast { position: fixed; bottom: 20px; right: 20px; background: #003366; color: white;
           padding: 10px 18px; border-radius: 4px; font-size: 13px; display: none; z-index: 200; }

  .search-bar { margin-bottom: 10px; }
  .search-bar input { width: 250px; }

  code { background: #eee; padding: 1px 5px; border-radius: 3px; font-size: 12px; }

  .schema-box { background: white; border: 1px solid #ccc; padding: 15px; font-family: monospace; font-size: 13px; line-height: 2; }
  .schema-box .entity { color: #003366; font-weight: bold; }
  .schema-box .pk { color: #b8860b; }
  .schema-box .fk { color: #0055aa; }

  .tabs { display: flex; border-bottom: 2px solid #003366; margin-bottom: 15px; }
  .tab { padding: 8px 16px; cursor: pointer; font-size: 13px; background: #ddd; margin-right: 3px; border-radius: 3px 3px 0 0; }
  .tab.active { background: #003366; color: white; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  .emi-result { background: #e8f0fe; border: 1px solid #003366; padding: 12px; margin-top: 12px; border-radius: 3px; font-size: 14px; }
</style>
</head>
