const fmt = n => '₹' + parseFloat(n).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2});
const custName = id => { const c=DB.customers.find(x=>x.id===id); return c?c.fname+' '+c.lname:'—'; };
const accNo = id => { const a=DB.accounts.find(x=>x.id===id); return a?'...'+a.accno.slice(-6):'—'; };
const kycBadge = s => s==='Verified'?'badge-green':s==='Pending'?'badge-yellow':'badge-red';
const statusBadge = s => s==='Active'?'badge-green':s==='Dormant'?'badge-grey':s==='Closed'?'badge-red':'badge-yellow';

function navigate(page, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.navbar a').forEach(a=>a.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  el.classList.add('active');
}

function renderAll() {
  // Customers
  document.getElementById('cust-tbody').innerHTML = DB.customers.map(c=>`
    <tr><td>${c.id}</td><td>${c.fname} ${c.lname}</td><td>${c.email}</td><td>${c.phone}</td>
    <td><code>${c.pan}</code></td><td><span class="badge ${kycBadge(c.kyc)}">${c.kyc}</span></td></tr>`).join('');

  // Accounts
  document.getElementById('acc-tbody').innerHTML = DB.accounts.map(a=>`
    <tr><td><code>...${a.accno.slice(-6)}</code></td><td>${custName(a.cid)}</td><td>${a.type}</td>
    <td>Branch ${a.bid}</td><td>${fmt(a.balance)}</td><td>${a.date}</td>
    <td><span class="badge ${statusBadge(a.status)}">${a.status}</span></td></tr>`).join('');

  // Transactions
  renderTransactions('');

  // Loans
  document.getElementById('loan-tbody').innerHTML = DB.loans.map(l=>{
    const r=l.rate/100/12,n=l.tenure,emi=l.principal*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1);
    return `<tr><td>L-${l.id}</td><td>${custName(l.cid)}</td><td>${l.type}</td>
    <td>${fmt(l.principal)}</td><td>${l.rate}%</td><td>${l.tenure} months</td>
    <td>${fmt(emi)}</td><td>${l.date}</td>
    <td><span class="badge ${statusBadge(l.status)}">${l.status}</span></td></tr>`;}).join('');

  // Cards
  document.getElementById('card-tbody').innerHTML = DB.cards.map(c=>{
    const acc=DB.accounts.find(a=>a.id===c.acc_id);
    return `<tr><td><code>XXXX-XXXX-XXXX-${c.number.slice(-4)}</code></td>
    <td>${acc?custName(acc.cid):'—'}</td><td>${c.type}</td><td>${c.expiry}</td>
    <td>${c.limit>0?fmt(c.limit):'N/A'}</td>
    <td><span class="badge ${statusBadge(c.status)}">${c.status}</span></td></tr>`;}).join('');

  // Branches
  document.getElementById('branch-tbody').innerHTML = DB.branches.map(b=>`
    <tr><td>${b.id}</td><td>${b.bank}</td><td>${b.name}</td>
    <td>${b.city}</td><td>${b.state}</td><td><code>${b.ifsc}</code></td></tr>`).join('');

  // Employees
  document.getElementById('emp-tbody').innerHTML = DB.employees.map(e=>`
    <tr><td>E-${e.id}</td><td>${e.fname} ${e.lname}</td><td>Branch ${e.bid}</td>
    <td>${e.role}</td><td>${fmt(e.salary)}</td><td>${e.date}</td></tr>`).join('');

  // Recent transactions (last 5)
  const recent=[...DB.transactions].slice(-5).reverse();
  document.getElementById('recent-tbody').innerHTML = recent.map(t=>`
    <tr><td><code>${t.ref}</code></td><td>${accNo(t.acc_id)}</td><td>${t.type}</td>
    <td>${fmt(t.amount)}</td><td>${t.date}</td><td>${t.desc}</td></tr>`).join('');
}

function renderTransactions(filter) {
  const data=filter?DB.transactions.filter(t=>t.type===filter):DB.transactions;
  document.getElementById('txn-tbody').innerHTML = data.map(t=>`
    <tr><td><code>${t.ref}</code></td><td>${accNo(t.acc_id)}</td><td>${t.type}</td>
    <td>${fmt(t.amount)}</td><td>${t.date}</td><td>${t.desc}</td></tr>`).join('');
}

function filterTxns(val){ renderTransactions(val); }

function filterTable(id,val){
  document.querySelectorAll('#'+id+' tbody tr').forEach(r=>{
    r.style.display=r.textContent.toLowerCase().includes(val.toLowerCase())?'':'none';
  });
}

function openModal(id){ document.getElementById('modal-'+id).classList.add('open'); }
function closeModal(id){ document.getElementById('modal-'+id).classList.remove('open'); }

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.display='block';
  setTimeout(()=>t.style.display='none',3000);
}

function addCustomer(){
  const f=document.getElementById('c-fname').value, l=document.getElementById('c-lname').value;
  const e=document.getElementById('c-email').value, p=document.getElementById('c-phone').value;
  if(!f||!l||!e||!p){alert('Please fill all required fields.');return;}
  DB.customers.push({id:DB.customers.length+1,fname:f,lname:l,email:e,phone:p,
    pan:document.getElementById('c-pan').value||'PENDING',kyc:'Pending'});
  renderAll(); closeModal('add-customer');
  showToast('Customer '+f+' '+l+' added successfully!');
  ['c-fname','c-lname','c-email','c-phone','c-pan'].forEach(x=>document.getElementById(x).value='');
}

function addAccount(){
  const cid=parseInt(document.getElementById('a-cid').value),
        bid=parseInt(document.getElementById('a-bid').value),
        type=document.getElementById('a-type').value,
        bal=parseFloat(document.getElementById('a-bal').value)||0;
  if(!cid||!bid){alert('Please enter Customer ID and Branch ID.');return;}
  const id=DB.accounts.length+1;
  DB.accounts.push({id,cid,bid,accno:String(id).padStart(16,'1001'),type,balance:bal,
    date:new Date().toISOString().split('T')[0],status:'Active'});
  renderAll(); closeModal('add-account');
  showToast(type+' account opened successfully!');
}

function addTransaction(){
  const acc=parseInt(document.getElementById('t-acc').value),
        type=document.getElementById('t-type').value,
        amt=parseFloat(document.getElementById('t-amt').value),
        desc=document.getElementById('t-desc').value;
  if(!acc||!amt){alert('Please enter Account ID and Amount.');return;}
  DB.transactions.push({id:DB.transactions.length+1,acc_id:acc,type,amount:amt,
    date:new Date().toISOString().split('T')[0],desc:desc||type,ref:'TXN'+Date.now()});
  renderAll(); closeModal('new-txn');
  showToast('Transaction of '+fmt(amt)+' done successfully!');
}

function calcEMI(){
  const P=parseFloat(document.getElementById('emi-p').value),
        r=parseFloat(document.getElementById('emi-r').value)/100/12,
        n=parseInt(document.getElementById('emi-n').value);
  if(!P||!r||!n){alert('Please fill all fields.');return;}
  const emi=P*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1);
  const total=emi*n, interest=total-P;
  document.getElementById('emi-result').style.display='block';
  document.getElementById('emi-result').innerHTML=
    '<b>Monthly EMI:</b> '+fmt(emi)+'&nbsp;&nbsp;|&nbsp;&nbsp;'+
    '<b>Total Payment:</b> '+fmt(total)+'&nbsp;&nbsp;|&nbsp;&nbsp;'+
    '<b>Total Interest:</b> '+fmt(interest);
}

function switchTab(id,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}

document.querySelectorAll('.modal-bg').forEach(m=>{
  m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');});
});

renderAll();
