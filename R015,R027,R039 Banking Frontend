        <div class="stab-content active" id="stab-er">
          <table><thead><tr><th>Entity</th><th>Primary Key</th><th>Key Attributes</th><th>Relationships</th></tr></thead>
          <tbody>
            <tr><td><b>BANK</b></td><td><span class="mono">bank_id</span></td><td>bank_name, swift_code, headquarters</td><td>1 BANK → many BRANCHes</td></tr>
            <tr><td><b>BRANCH</b></td><td><span class="mono">branch_id</span></td><td>branch_name, city, ifsc_code</td><td>1 BRANCH → many EMPLOYEEs, ACCOUNTs, LOANs</td></tr>
            <tr><td><b>EMPLOYEE</b></td><td><span class="mono">emp_id</span></td><td>first_name, last_name, role, salary</td><td>Many EMPLOYEEs → 1 BRANCH</td></tr>
            <tr><td><b>CUSTOMER</b></td><td><span class="mono">customer_id</span></td><td>pan_number, kyc_status, email</td><td>1 CUSTOMER → many ACCOUNTs, LOANs</td></tr>
            <tr><td><b>ACCOUNT</b></td><td><span class="mono">account_id</span></td><td>account_number, type, balance, status</td><td>1 ACCOUNT → many TRANSACTIONs, CARDs</td></tr>
            <tr><td><b>TRANSACTION</b></td><td><span class="mono">txn_id</span></td><td>txn_type, amount, txn_date, reference_no</td><td>Many TRANSACTIONs → 1 ACCOUNT</td></tr>
            <tr><td><b>CARD</b></td><td><span class="mono">card_id</span></td><td>card_number, card_type, expiry_date</td><td>Many CARDs → 1 ACCOUNT</td></tr>
            <tr><td><b>LOAN</b></td><td><span class="mono">loan_id</span></td><td>loan_type, principal, interest_rate, tenure</td><td>1 LOAN → many LOAN_PAYMENTs</td></tr>
            <tr><td><b>LOAN_PAYMENT</b></td><td><span class="mono">payment_id</span></td><td>emi_amount, principal_part, interest_part</td><td>Many PAYMENTs → 1 LOAN</td></tr>
          </tbody></table>
        </div>
        <div class="stab-content" id="stab-rel">
          <div class="rel-table">
            <div><span class="entity">BANK</span>(<span class="pk">bank_id</span>, bank_name, headquarters, established_year, swift_code)</div>
            <div><span class="entity">BRANCH</span>(<span class="pk">branch_id</span>, <span class="fk">bank_id*</span>, branch_name, city, state, ifsc_code)</div>
            <div><span class="entity">EMPLOYEE</span>(<span class="pk">emp_id</span>, <span class="fk">branch_id*</span>, first_name, last_name, role, salary, hire_date)</div>
            <div><span class="entity">CUSTOMER</span>(<span class="pk">customer_id</span>, first_name, last_name, dob, email, phone, address, pan_number, kyc_status)</div>
            <div><span class="entity">ACCOUNT</span>(<span class="pk">account_id</span>, <span class="fk">customer_id*</span>, <span class="fk">branch_id*</span>, account_number, account_type, balance, open_date, status)</div>
            <div><span class="entity">TRANSACTION</span>(<span class="pk">txn_id</span>, <span class="fk">account_id*</span>, txn_type, amount, txn_date, description, reference_no)</div>
            <div><span class="entity">CARD</span>(<span class="pk">card_id</span>, <span class="fk">account_id*</span>, card_number, card_type, expiry_date, credit_limit, status)</div>
            <div><span class="entity">LOAN</span>(<span class="pk">loan_id</span>, <span class="fk">customer_id*</span>, <span class="fk">branch_id*</span>, loan_type, principal, interest_rate, tenure_months, disburse_date, status)</div>
            <div><span class="entity">LOAN_PAYMENT</span>(<span class="pk">payment_id</span>, <span class="fk">loan_id*</span>, payment_date, emi_amount, principal_part, interest_part)</div>
            <br><div style="font-size:.8rem;color:var(--color-text-muted)"><span class="pk">gold</span> = Primary Key &nbsp;|&nbsp; <span class="fk">blue*</span> = Foreign Key</div>
          </div>
        </div>
        <div class="stab-content" id="stab-norm">
          <table><thead><tr><th>Normal Form</th><th>Condition</th><th>Status</th><th>Explanation</th></tr></thead>
          <tbody>
            <tr><td><b>1NF</b></td><td>Atomic values, no repeating groups</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All columns hold single atomic values. Each row is unique via primary key.</td></tr>
            <tr><td><b>2NF</b></td><td>No partial dependency on composite key</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All PKs are single-column surrogate keys, so partial dependency cannot exist.</td></tr>
            <tr><td><b>3NF</b></td><td>No transitive dependency</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>Branch details in BRANCH table, not in ACCOUNT. No non-key → non-key dependency.</td></tr>
            <tr><td><b>BCNF</b></td><td>Every determinant is a candidate key</td><td><span class="badge badge-green">Satisfied ✓</span></td><td>All FDs have superkeys as determinants. Unique constraints enforce candidate keys.</td></tr>
          </tbody></table>
