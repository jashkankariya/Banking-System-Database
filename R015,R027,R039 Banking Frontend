<script>
const API = 'http://127.0.0.1:5000/api';
const fmt = n => '₹' + parseFloat(n).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2});

// ── THEME ──
(function(){
  const t=document.querySelector('[data-theme-toggle]'),r=document.documentElement;
  let d=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
  r.setAttribute('data-theme',d);
  t&&t.addEventListener('click',()=>{
    d=d==='dark'?'light':'dark';r.setAttribute('data-theme',d);
    t.innerHTML=d==='dark'
      ?'<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>'
      :'<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  });
})();

// ── NAV ──
function navigate(page, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(a=>a.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  el.classList.add('active');
  document.getElementById('page-title').textContent = el.dataset.title;
  loadPage(page);
}
function refreshPage(){
  const active = document.querySelector('.nav-item.active');
  if(active) loadPage(active.getAttribute('onclick').match(/'(\w+)'/)[1]);
}
function loadPage(page){
  const loaders = {
    dashboard: loadDashboard,
    customers: loadCustomers,
    accounts: loadAccounts,
    transactions: ()=>loadTransactions(''),
    loans: loadLoans,
    cards: loadCards,
    branches: loadBranches,
    employees: loadEmployees
  };
  if(loaders[page]) loaders[page]();
}

// ── FETCH HELPER ──
async function apiFetch(url, opts={}) {
  try {
    const res = await fetch(API + url, opts);
    return await res.json();
  } catch(e) {
    showToast('⚠️ Cannot connect to Flask server. Is app.py running?', true);
    return null;
  }
}

// ── TOAST ──
function showToast(msg, err=false){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.style.background = err ? 'var(--color-error)' : 'var(--color-text)';
  t.style.display='block';
  setTimeout(()=>t.style.display='none',3500);
}

// ── MODAL ──
function openModal(id){document.getElementById('modal-'+id).classList.add('open')}
function closeModal(id){document.getElementById('modal-'+id).classList.remove('open')}
document.querySelectorAll('.modal-bg').forEach(m=>{
  m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open')});
});

// ── FILTER ──
function filterTable(id, val){
  document.querySelectorAll('#'+id+' tbody tr').forEach(r=>{
    r.style.display=r.textContent.toLowerCase().includes(val.toLowerCase())?'':'none';
  });
}

// ── BADGES ──
const kycBadge = s => s==='Verified'?'badge-green':s==='Pending'?'badge-yellow':'badge-red';
const statusBadge = s => ({Active:'badge-green',Dormant:'badge-grey',Closed:'badge-red',Expired:'badge-red'}[s]||'badge-grey');
const txnBadge = s => ({Deposit:'badge-green',Withdrawal:'badge-red',Transfer:'badge-blue','EMI Payment':'badge-yellow','Interest Credit':'badge-gold'}[s]||'badge-grey');

// ── DASHBOARD ──
async function loadDashboard(){
  const d = await apiFetch('/dashboard');
  if(!d) return;
  const kpis = [
    {n:d.customers,l:'Customers',bg:'var(--color-primary-highlight)',c:'var(--color-primary)'},
    {n:d.accounts,l:'Accounts',bg:'var(--color-primary-highlight)',c:'var(--color-primary)'},
    {n:d.transactions,l:'Transactions',bg:'var(--color-success-highlight)',c:'var(--color-success)'},
    {n:d.loans,l:'Active Loans',bg:'var(--color-warning-highlight)',c:'var(--color-warning)'},
    {n:d.branches,l:'Branches',bg:'var(--color-primary-highlight)',c:'var(--color-primary)'},
    {n:d.employees,l:'Employees',bg:'var(--color-success-highlight)',c:'var(--color-success)'},
  ];
  const icons = ['icon-users','icon-credit-card','icon-arrow-left-right','icon-landmark','icon-map-pin','icon-user-check'];
  document.getElementById('kpi-grid').innerHTML = kpis.map((k,i)=>`
    <div class="kpi-card">
      <div class="kpi-icon" style="background:${k.bg};color:${k.c}"><i class="${icons[i]}" style="font-size:18px"></i></div>
      <div class="kpi-num">${k.n}</div><div class="kpi-label">${k.l}</div>
    </div>`).join('');
  document.getElementById('recent-tbody').innerHTML = d.recent.map(t=>`
    <tr><td><span class="mono">${t.reference_no}</span></td>
    <td><span class="mono">${t.account_number}</span></td>
    <td><span class="badge ${txnBadge(t.txn_type)}">${t.txn_type}</span></td>
    <td><b>${fmt(t.amount)}</b></td><td>${t.txn_date}</td><td>${t.description}</td></tr>`).join('');
}

// ── CUSTOMERS ──
async function loadCustomers(){
  const data = await apiFetch('/customers');
  if(!data) return;
  document.getElementById('cust-tbody').innerHTML = data.map(c=>`
    <tr><td>${c.customer_id}</td><td><b>${c.full_name}</b></td>
    <td>${c.email}</td><td>${c.phone}</td>
    <td><span class="mono">${c.pan_number}</span></td>
    <td><span class="badge ${kycBadge(c.kyc_status)}">${c.kyc_status}</span></td></tr>`).join('');
}
async function addCustomer(){
  const f=v=>document.getElementById(v).value;
  if(!f('c-fname')||!f('c-lname')||!f('c-email')){alert('Fill required fields');return;}
  const res = await apiFetch('/customers',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({fname:f('c-fname'),lname:f('c-lname'),email:f('c-email'),phone:f('c-phone'),pan:f('c-pan')})});
  if(res?.success){closeModal('add-customer');loadCustomers();showToast('Customer added successfully!');}
}

// ── ACCOUNTS ──
async function loadAccounts(){
  const data = await apiFetch('/accounts');
  if(!data) return;
  document.getElementById('acc-tbody').innerHTML = data.map(a=>`
    <tr><td><span class="mono">${a.account_number}</span></td>
    <td>${a.customer_name}</td><td>${a.account_type}</td>
    <td>${a.branch_name}</td><td><b>${fmt(a.balance)}</b></td>
    <td>${a.open_date}</td>
    <td><span class="badge ${statusBadge(a.status)}">${a.status}</span></td></tr>`).join('');
}
async function addAccount(){
  const f=v=>document.getElementById(v).value;
  if(!f('a-cid')||!f('a-bid')){alert('Fill Customer ID and Branch ID');return;}
  const res = await apiFetch('/accounts',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({customer_id:+f('a-cid'),branch_id:+f('a-bid'),account_type:f('a-type'),balance:+f('a-bal')})});
  if(res?.success){closeModal('add-account');loadAccounts();showToast('Account opened successfully!');}
}

// ── TRANSACTIONS ──
async function loadTransactions(filter=''){
  const data = await apiFetch('/transactions'+(filter?`?type=${filter}`:''));
  if(!data) return;
  document.getElementById('txn-tbody').innerHTML = data.map(t=>`
    <tr><td><span class="mono">${t.reference_no}</span></td>
    <td><span class="mono">${t.account_number}</span></td>
    <td><span class="badge ${txnBadge(t.txn_type)}">${t.txn_type}</span></td>
    <td><b>${fmt(t.amount)}</b></td><td>${t.txn_date}</td><td>${t.description}</td></tr>`).join('');
}
async function addTransaction(){
  const f=v=>document.getElementById(v).value;
  if(!f('t-acc')||!f('t-amt')){alert('Fill Account ID and Amount');return;}
  const res = await apiFetch('/transactions',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({account_id:+f('t-acc'),txn_type:f('t-type'),amount:+f('t-amt'),description:f('t-desc')})});
  if(res?.success){closeModal('new-txn');loadTransactions('');showToast(`Transaction recorded! Ref: ${res.ref}`);}
}

// ── LOANS ──
async function loadLoans(){
  const data = await apiFetch('/loans');
  if(!data) return;
  const active=data.filter(l=>l.status==='Active').length;
  const closed=data.filter(l=>l.status==='Closed').length;
  const total=data.reduce((s,l)=>s+parseFloat(l.principal),0);
  document.getElementById('loan-kpis').innerHTML = [
    {n:active,l:'Active Loans',bg:'var(--color-success-highlight)',c:'var(--color-success)'},
    {n:closed,l:'Closed Loans',bg:'var(--color-warning-highlight)',c:'var(--color-warning)'},
    {n:'₹'+Math.round(total/10000000*100)/100+' Cr',l:'Total Disbursed',bg:'var(--color-primary-highlight)',c:'var(--color-primary)'},
  ].map(k=>`<div class="kpi-card"><div class="kpi-num" style="color:${k.c}">${k.n}</div><div class="kpi-label">${k.l}</div></div>`).join('');
  document.getElementById('loan-tbody').innerHTML = data.map(l=>{
    const r=l.interest_rate/100/12,n=l.tenure_months;
    const emi=l.principal*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1);
    return `<tr><td>L-${l.loan_id}</td><td>${l.customer_name}</td><td>${l.loan_type}</td>
    <td>${fmt(l.principal)}</td><td>${l.interest_rate}%</td><td>${l.tenure_months}m</td>
    <td><b>${fmt(emi)}</b></td><td>${l.disburse_date}</td>
    <td><span class="badge ${statusBadge(l.status)}">${l.status}</span></td></tr>`;}).join('');
}
function calcEMI(){
  const P=+document.getElementById('emi-p').value,r=+document.getElementById('emi-r').value/100/12,n=+document.getElementById('emi-n').value;
  if(!P||!r||!n)return;
  const emi=P*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1),total=emi*n;
  document.getElementById('emi-result').style.display='flex';
  document.getElementById('emi-monthly').textContent=fmt(emi);
  document.getElementById('emi-total').textContent=fmt(total);
  document.getElementById('emi-interest').textContent=fmt(total-P);
}

// ── CARDS ──
async function loadCards(){
  const data = await apiFetch('/cards');
  if(!data) return;
  document.getElementById('card-tbody').innerHTML = data.map(c=>`
    <tr><td><span class="mono">XXXX-XXXX-XXXX-${String(c.card_number).slice(-4)}</span></td>
    <td>${c.customer_name}</td><td>${c.card_type}</td>
    <td>${c.expiry_date}</td><td>${c.credit_limit>0?fmt(c.credit_limit):'N/A'}</td>
    <td><span class="badge ${statusBadge(c.status)}">${c.status}</span></td></tr>`).join('');
}

// ── BRANCHES ──
async function loadBranches(){
  const data = await apiFetch('/branches');
