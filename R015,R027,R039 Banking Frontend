</div>

<div class="container">

  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <h2>Dashboard — Overview</h2>
    <div class="kpi-row">
      <div class="kpi"><div class="num">12</div><div class="lbl">Total Customers</div></div>
      <div class="kpi"><div class="num">13</div><div class="lbl">Total Accounts</div></div>
      <div class="kpi"><div class="num">20</div><div class="lbl">Transactions</div></div>
      <div class="kpi"><div class="num">10</div><div class="lbl">Active Loans</div></div>
      <div class="kpi"><div class="num">10</div><div class="lbl">Branches</div></div>
      <div class="kpi"><div class="num">12</div><div class="lbl">Employees</div></div>
    </div>
    <div class="card">
      <h3>Recent Transactions</h3>
      <table>
        <thead><tr><th>Ref No.</th><th>Account</th><th>Type</th><th>Amount (₹)</th><th>Date</th><th>Description</th></tr></thead>
        <tbody id="recent-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- CUSTOMERS -->
  <div class="page" id="page-customers">
    <h2>Customer Management</h2>
    <div style="margin-bottom:10px">
      <button onclick="openModal('add-customer')">+ Add Customer</button>
      <span class="search-bar" style="display:inline-block;margin-left:10px">
        <input type="text" placeholder="Search customers..." oninput="filterTable('cust-table',this.value)" style="width:220px">
      </span>
    </div>
    <table id="cust-table">
      <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>PAN</th><th>KYC Status</th></tr></thead>
      <tbody id="cust-tbody"></tbody>
    </table>
  </div>

  <!-- ACCOUNTS -->
  <div class="page" id="page-accounts">
    <h2>Account Management</h2>
    <div style="margin-bottom:10px">
      <button onclick="openModal('add-account')">+ Open New Account</button>
    </div>
    <table id="acc-table">
      <thead><tr><th>Acc No.</th><th>Customer</th><th>Type</th><th>Branch</th><th>Balance (₹)</th><th>Open Date</th><th>Status</th></tr></thead>
      <tbody id="acc-tbody"></tbody>
    </table>
  </div>

  <!-- TRANSACTIONS -->
  <div class="page" id="page-transactions">
    <h2>Transaction History</h2>
    <div style="margin-bottom:10px">
      <button onclick="openModal('new-txn')">+ New Transaction</button>
      <select onchange="filterTxns(this.value)" style="width:160px;margin-left:10px">
        <option value="">All Types</option>
        <option>Deposit</option><option>Withdrawal</option>
        <option>Transfer</option><option>EMI Payment</option><option>Interest Credit</option>
      </select>
    </div>
    <table id="txn-table">
      <thead><tr><th>Ref No.</th><th>Account</th><th>Type</th><th>Amount (₹)</th><th>Date</th><th>Description</th></tr></thead>
      <tbody id="txn-tbody"></tbody>
    </table>
  </div>

  <!-- LOANS -->
  <div class="page" id="page-loans">
    <h2>Loan Management</h2>
    <div class="kpi-row">
      <div class="kpi"><div class="num">8</div><div class="lbl">Active Loans</div></div>
      <div class="kpi"><div class="num">2</div><div class="lbl">Closed Loans</div></div>
      <div class="kpi"><div class="num">₹7.60 Cr</div><div class="lbl">Total Disbursed</div></div>
    </div>
    <table>
      <thead><tr><th>Loan ID</th><th>Customer</th><th>Type</th><th>Principal (₹)</th><th>Rate %</th><th>Tenure</th><th>Monthly EMI (₹)</th><th>Disburse Date</th><th>Status</th></tr></thead>
      <tbody id="loan-tbody"></tbody>
    </table>

    <div class="card" style="margin-top:20px">
